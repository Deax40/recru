# ─── Base de données ──────────────────────────────────────────────────────────
# Développement local (SQLite) — copier dans .env et laisser tel quel
DATABASE_URL="file:./prisma/dev.db"

# Production (PostgreSQL sur Neon / PlanetScale / Supabase)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET="REMPLACER_PAR_UNE_VRAIE_CLE_ALEATOIRE_32_CHARS"

# URL de l'application (sans slash final)
# Développement :
NEXTAUTH_URL="http://localhost:3000"
# Production (Vercel) :
# NEXTAUTH_URL="https://votre-app.vercel.app"
